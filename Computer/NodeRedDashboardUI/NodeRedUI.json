        "name": "",
        "order": 0,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template></template>\n\n<script>\nexport default {\n  mounted() {\n    const justLoggedIn = sessionStorage.getItem(\"justLoggedIn\")\n    const refreshLogout = sessionStorage.getItem(\"refreshLogout\")\n\n    // First load right after login: allow it\n    if (justLoggedIn === \"true\") {\n      sessionStorage.removeItem(\"justLoggedIn\")\n      sessionStorage.removeItem(\"refreshLogout\")\n      return\n    }\n\n    // Only logout if the browser was actually refreshed\n    if (refreshLogout === \"true\") {\n      sessionStorage.removeItem(\"refreshLogout\")\n\n      this.send({\n        topic: \"refresh_logout\",\n        payload: true\n      })\n    }\n\n    // Mark refresh/close for the next load\n    window.addEventListener(\"beforeunload\", this.markRefresh)\n  },\n\n  beforeUnmount() {\n    window.removeEventListener(\"beforeunload\", this.markRefresh)\n  },\n\n  methods: {\n    markRefresh() {\n      sessionStorage.setItem(\"refreshLogout\", \"true\")\n    }\n  }\n}\n</script>",
