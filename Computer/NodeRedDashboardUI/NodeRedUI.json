        "format": "<template>\n  <div class=\"bg-shapes\">\n    <div class=\"shape shape1\"></div>\n    <div class=\"shape shape2\"></div>\n    <div class=\"shape shape3\"></div>\n  </div>\n</template>\n\n<style>\n \n  \n.bg-shapes {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  z-index: -1;\n}\n\n/* Common shape style */\n.shape {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(0px);\n  opacity: 0.35;\n  animation: float 14s ease-in-out infinite;\n}\n\n/* Top-left */\n.shape1 {\n  width: 500px;\n  height: 500px;\n  background: #297d41;\n  top: -150px;\n  left: -150px;\n}\n\n/* Bottom-right */\n.shape2 {\n  width: 600px;\n  height: 600px;\n  background: #297d41;\n  bottom: -200px;\n  right: -200px;\n  animation-delay: 2s;\n}\n\n/* Middle shape (your 3rd one) */\n.shape3 {\n  width: 300px;\n  height: 300px;\n  background: #297d41;\n  bottom: 50px;\n  right: 800px;\n  animation-delay: 4s;\n}\n\n/* Animation */\n@keyframes float {\n  0% {\n    transform: translate(0px, 0px);\n  }\n  50% {\n    transform: translate(30px, -40px);\n  }\n  100% {\n    transform: translate(0px, 0px);\n  }\n}\n</style>",
