    {
        "id": "b3a8ee133902d20a",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Go To Home",
        "func": "if (msg.payload && msg.payload.status === \"success\") {\n    flow.set(\"loggedIn\", true);\n\n    let oldTimer = flow.get(\"logoutTimer\");\n    if (oldTimer) {\n        clearTimeout(oldTimer);\n    }\n\n    let timer = setTimeout(() => {\n        flow.set(\"loggedIn\", false);\n\n        node.send({\n            payload: {\n                page: \"Login\",\n                pages: {\n                    hide: [\"Smart Door Devices\"],\n                    show: [\"Login\"]\n                }\n            }\n        });\n    }, 5 * 60 * 1000);\n\n    flow.set(\"logoutTimer\", timer);\n\n    msg.payload = {\n        page: \"Smart Door Devices\",\n        pages: {\n            hide: [\"Login\"],\n            show: [\"Smart Door Devices\"]\n        },\n        justLoggedIn: true\n    };\n\n    return msg;\n}\n\nreturn null;",
