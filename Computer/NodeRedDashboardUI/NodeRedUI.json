        "id": "05fd578fccd55aa8",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Check Credentials",
        "func": "let username = msg.payload.username || \"\";\nlet password = msg.payload.password || \"\";\n\nif (username === \"admin\" && password === \"1234\") {\n    flow.set(\"loggedIn\", true);\n    flow.set(\"logoutAt\", Date.now() + 5 * 60 * 1000);\n\n    msg.payload = {\n        status: \"success\",\n        message: \"Login successful! Redirecting...\"\n    };\n} else {\n    flow.set(\"loggedIn\", false);\n    flow.set(\"logoutAt\", null);\n\n    msg.payload = {\n        status: \"fail\",\n        message: \"Invalid username or password.\"\n    };\n}\n\nreturn msg;",
