    /* ======================================================================
       MQTT IN – qorvo/demo/button
       Receives button press/release events from the QPG6200 via the
       gateway bridge. Passes them to func_btn_door to drive the Doorbell.
    ====================================================================== */
    {
        "id": "mqtt_in_btn",
        "type": "mqtt in",
        "z": "d500a277468611a9",
        "name": "Button State In",
        "topic": "qorvo/demo/button",
        "qos": "0",
        "datatype": "json",
        "broker": "ble_demo_broker",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 140,
        "y": 1060,
        "wires": [["func_btn_door"]]
    },

    /* ======================================================================
       FUNCTION – Button → Doorbell
       Converts a button-press event from the QPG6200 into the exact
       message format that the existing Doorbell Function node expects,
       so the dashboard animates, plays audio, and shows a notification.
       Release events are ignored (doorbell only rings on press).
    ====================================================================== */
    {
        "id": "func_btn_door",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Button → Doorbell",
        "func": "// Only trigger the doorbell on button press, ignore release\nvar data = msg.payload;\nif (!data || data.state !== 'pressed') {\n    return null;\n}\n\n// This is the exact message format the Doorbell Function node expects\nreturn {\n    topic: 'doorbell_press',\n    payload: true\n};\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 1060,
        "wires": [["0e86246dc8a9a3fa"]]
    },

    /* ======================================================================
       MQTT IN – qorvo/demo/heartbeat
       Receives the 5-second alive counter from the QPG6200.
       Drives both the Movement Detector status and the heartbeat display.
    ====================================================================== */
    {
        "id": "mqtt_in_hb",
        "type": "mqtt in",
        "z": "d500a277468611a9",
        "name": "Heartbeat In",
        "topic": "qorvo/demo/heartbeat",
        "qos": "0",
        "datatype": "json",
        "broker": "ble_demo_broker",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 140,
        "y": 1140,
        "wires": [["func_hb_disp"]]
    },

    /* ======================================================================
       FUNCTION – Heartbeat → Motion + Counter display
       Output 1: "Motion DETECTED" string → existing Status Indicator template
                 (turns the indicator green while device is sending heartbeats)
       Output 2: "💓 N" string → QPG6200 Device heartbeat text widget
    ====================================================================== */
    {
        "id": "func_hb_disp",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Heartbeat → Motion + Counter",
        "func": "var data = msg.payload;\nvar count = (data && data.count !== undefined) ? data.count : '?';\n\n// Output 1: Motion Detected (existing Status Indicator expects this string)\nvar motionMsg = { payload: 'Motion DETECTED' };\n\n// Output 2: Heartbeat counter for the QPG6200 Device group\nvar counterMsg = { payload: '💓 ' + count };\n\nreturn [motionMsg, counterMsg];\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 1140,
        "wires": [
            ["19f8f8e36112e167"],
            ["txt_qpg_hb"]
        ]
    },

    /* ======================================================================
       MQTT IN – qorvo/demo/status
       Receives BLE connection status changes from the gateway bridge.
       Drives both the Speaker/Mic display and the connection status text.
    ====================================================================== */
    {
        "id": "mqtt_in_stat",
        "type": "mqtt in",
        "z": "d500a277468611a9",
        "name": "BLE Status In",
        "topic": "qorvo/demo/status",
        "qos": "0",
        "datatype": "json",
        "broker": "ble_demo_broker",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 140,
        "y": 1220,
        "wires": [["func_stat_disp"]]
    },

    /* ======================================================================
       FUNCTION – Status → Speaker/Mic + Connection Text
       Output 1: boolean true/false → Speaker UI template
                 (true = "Speaker detected", false = "No sound detected")
       Output 2: status string  → QPG6200 Device connection text widget
    ====================================================================== */
    {
        "id": "func_stat_disp",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Status → Speaker + Text",
        "func": "var data = msg.payload;\nvar connected = data && data.connected === true;\nvar device = (data && data.device) ? data.device : 'QPG6200';\n\n// Output 1: Speaker UI expects true (active) or false (inactive)\nvar speakerMsg = { payload: connected };\n\n// Output 2: Human-readable status for the QPG6200 Device group\nvar statusMsg = {\n    payload: connected\n        ? ('✅ Connected – ' + device)\n        : ('❌ Disconnected – ' + device)\n};\n\nreturn [speakerMsg, statusMsg];\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 1220,
        "wires": [
            ["a26d1ac63796f21e"],
            ["txt_qpg_conn"]
        ]
    },

