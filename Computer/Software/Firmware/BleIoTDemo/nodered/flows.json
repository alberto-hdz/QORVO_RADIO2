        "format": "<template>\n  <div style=\"position: absolute; top: 20px; left: 50%; transform: translateX(-50%); z-index: 1000; color: white; font-weight: normal; font-size: 20px; white-space: nowrap;\">\n    Auto Logout in {{ minutes }}:{{ seconds }}\n  </div>\n</template>\n\n<script>\nexport default {\n  data() { return { remaining: 300, timer: null } },\n  computed: {\n    minutes() { return Math.floor(this.remaining / 60) },\n    seconds() { return String(this.remaining % 60).padStart(2, \"0\") }\n  },\n  mounted() {\n    this.remaining = 300;\n    this.timer = setInterval(() => { if (this.remaining > 0) this.remaining--; else clearInterval(this.timer); }, 1000);\n  },\n  beforeUnmount() { if (this.timer) clearInterval(this.timer); }\n}\n</script>",
