        "qos": "0",
        "retain": "false",
        "broker": "ble_demo_broker",
        "x": 870,
        "y": 1300,
        "wires": []
    },

    /* ======================================================================
       FUNCTION – Lighting Switch → LED Command
       Converts the Light Switch string value to a JSON LED command and
       publishes to the MQTT LED topic to control the QPG6200 BLUE LED.
    ====================================================================== */
    {
        "id": "func_light_led",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Light Switch → LED Command",
        "func": "// The Light Switch sends 'Motion DETECTED' (on) or 'No motion detected' (off)\nif (msg.payload === 'Motion DETECTED') {\n    msg.payload = JSON.stringify({ led: 'on' });\n} else {\n    msg.payload = JSON.stringify({ led: 'off' });\n}\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 1300,
        "wires": [["mqtt_out_led_main"]]
    },

    /* ======================================================================
       FUNCTION – Doorbell Ring → LED Flash
       When the doorbell rings (either from the dashboard button OR from the
       QPG6200 physical button), the QPG6200 BLUE LED flashes for 3 seconds
       to provide local visual feedback at the device.
    ====================================================================== */
    {
        "id": "func_door_led_flash",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Doorbell → LED Flash",
        "func": "// Flash the QPG6200 BLUE LED for 3 seconds on doorbell ring\nnode.send({ payload: JSON.stringify({ led: 'on' }) });\n\nsetTimeout(function() {\n    node.send({ payload: JSON.stringify({ led: 'off' }) });\n}, 3000);\n\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 1360,
        "wires": [["mqtt_out_led_main"]]
    },

