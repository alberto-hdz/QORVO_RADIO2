    {
        "id": "05fd578fccd55aa8",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Check Credentials",
        "func": "let username = msg.payload.username || \"\";\nlet password = msg.payload.password || \"\";\n\nif (username === \"admin\" && password === \"1234\") {\n    flow.set(\"loggedIn\", true);\n    flow.set(\"logoutAt\", Date.now() + 5 * 60 * 1000);\n    msg.payload = { status: \"success\", message: \"Login successful! Redirecting...\" };\n} else {\n    flow.set(\"loggedIn\", false);\n    flow.set(\"logoutAt\", null);\n    msg.payload = { status: \"fail\", message: \"Invalid username or password.\" };\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 60,
        "wires": [["b3a8ee133902d20a"]]
    },
    {
        "id": "b3a8ee133902d20a",
        "type": "function",
        "z": "d500a277468611a9",
        "name": "Go To Home",
        "func": "if (msg.payload && msg.payload.status === \"success\") {\n    flow.set(\"loggedIn\", true);\n    let oldTimer = flow.get(\"logoutTimer\");\n    if (oldTimer) clearTimeout(oldTimer);\n    let timer = setTimeout(() => {\n        flow.set(\"loggedIn\", false);\n        node.send({ payload: { page: \"Login\", pages: { hide: [\"Smart Door Devices\"], show: [\"Login\"] } } });\n    }, 5 * 60 * 1000);\n    flow.set(\"logoutTimer\", timer);\n    msg.payload = { page: \"Smart Door Devices\", pages: { hide: [\"Login\"], show: [\"Smart Door Devices\"] }, justLoggedIn: true };\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
