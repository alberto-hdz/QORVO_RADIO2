        "format": "<template></template>\n\n<script>\nexport default {\n  mounted() {\n    const justLoggedIn = sessionStorage.getItem(\"justLoggedIn\")\n    const refreshLogout = sessionStorage.getItem(\"refreshLogout\")\n    if (justLoggedIn === \"true\") {\n      sessionStorage.removeItem(\"justLoggedIn\")\n      sessionStorage.removeItem(\"refreshLogout\")\n      return\n    }\n    if (refreshLogout === \"true\") {\n      sessionStorage.removeItem(\"refreshLogout\")\n      this.send({ topic: \"refresh_logout\", payload: true })\n    }\n    window.addEventListener(\"beforeunload\", this.markRefresh)\n  },\n  beforeUnmount() { window.removeEventListener(\"beforeunload\", this.markRefresh) },\n  methods: { markRefresh() { sessionStorage.setItem(\"refreshLogout\", \"true\") } }\n}\n</script>",
